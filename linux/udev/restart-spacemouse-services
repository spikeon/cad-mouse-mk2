#!/bin/bash
# Called by udev on CAD Mouse MK2 plug-in.
# Uses delayed restarts (systemd-run) to avoid race conditions where
# spacenavd starts before the device finishes enumerating.
# spacenav-ws is intentionally NOT restarted here — it reconnects to
# spacenavd automatically, keeping the OnShape WebSocket alive.

# Find the first non-root interactive user session
ACTIVE_USER=$(loginctl list-sessions --no-legend 2>/dev/null \
    | awk '$3 != "root" {print $3; exit}')
if [ -z "$ACTIVE_USER" ]; then
    ACTIVE_USER=$(who | awk '$1 != "root" {print $1; exit}')
fi

# Restart spacenavd after 2s — device needs to finish USB enumeration first
systemd-run --no-block --on-active=2 /usr/bin/systemctl restart spacenavd

# Restart spnav-buttons after 3s — hidraw device must exist before it opens
if [ -n "$ACTIVE_USER" ]; then
    systemd-run --no-block --on-active=3 \
        /usr/bin/systemctl --user --machine="${ACTIVE_USER}@.host" restart spnav-buttons
fi
